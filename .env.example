# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use whichever key name your Supabase project provides:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gmail SMTP (for order notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Admin notification defaults (also configurable from dashboard)
ADMIN_EMAIL=your-email@gmail.com
ADMIN_PHONE=0000000000

# UPI Payment (NEXT_PUBLIC_ prefix required for client-side access)
NEXT_PUBLIC_UPI_ID=your-upi-id@bank
NEXT_PUBLIC_UPI_PAYEE=Your Store Name

# Telegram Bot (optional mobile notification)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
